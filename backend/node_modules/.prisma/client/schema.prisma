// Prisma Schema for TravelNest - Booking.com Clone (SQLite version)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════
// USER & AUTH
// ═══════════════════════════════════════════════════

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  passwordHash   String
  fullName       String
  phone          String?
  avatar         String?
  nationality    String?
  dateOfBirth    DateTime?
  passportNumber String?
  role           String    @default("USER")
  loyaltyPoints  Int       @default(0)
  tier           String    @default("BASIC")
  travelCredits  Float     @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  bookings      Booking[]
  payments      Payment[]
  reviews       Review[]
  searchLogs    SearchLog[]
  savedSearches SavedSearch[]
  wishlist      Wishlist[]
  flightSeats   FlightSeat[]

  @@map("users")
}

// ═══════════════════════════════════════════════════
// HOTELS
// ═══════════════════════════════════════════════════

model Hotel {
  id                 String   @id @default(uuid())
  name               String
  slug               String   @unique
  description        String
  starRating         Int      @default(3)
  address            String
  city               String
  state              String?
  country            String   @default("India")
  lat                Float
  lng                Float
  amenities          String   @default("[]")
  images             String   @default("[]")
  checkInTime        String   @default("14:00")
  checkOutTime       String   @default("12:00")
  cancellationPolicy String   @default("FREE_CANCELLATION")
  basePrice          Float
  currency           String   @default("INR")
  totalRooms         Int      @default(50)
  availableRooms     Int      @default(50)
  contactPhone       String?
  contactEmail       String?
  website            String?
  featured           Boolean  @default(false)
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  roomTypes RoomType[]
  reviews   Review[]
  bookings  Booking[]
  wishlist  Wishlist[]

  @@index([city])
  @@index([country])
  @@index([starRating])
  @@index([basePrice])
  @@map("hotels")
}

model RoomType {
  id             String   @id @default(uuid())
  hotelId        String
  hotel          Hotel    @relation(fields: [hotelId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  maxOccupancy   Int      @default(2)
  bedType        String   @default("DOUBLE")
  size           Int?
  basePrice      Float
  currentPrice   Float
  amenities      String   @default("[]")
  images         String   @default("[]")
  totalRooms     Int      @default(10)
  availableRooms Int      @default(10)
  available      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([hotelId])
  @@map("room_types")
}

// ═══════════════════════════════════════════════════
// FLIGHTS
// ═══════════════════════════════════════════════════

model Flight {
  id                     String   @id @default(uuid())
  flightNumber           String   @unique
  airline                String
  airlineCode            String
  airlineLogo            String?
  origin                 String
  originCity             String
  destination            String
  destinationCity        String
  departureTime          DateTime
  arrivalTime            DateTime
  duration               Int
  aircraft               String?
  totalSeats             Int      @default(180)
  stops                  Int      @default(0)
  stopCities             String   @default("[]")
  economyBasePrice       Float
  businessBasePrice      Float?
  firstClassBasePrice    Float?
  economyCurrentPrice    Float
  businessCurrentPrice   Float?
  firstClassCurrentPrice Float?
  economySeatsLeft       Int      @default(120)
  businessSeatsLeft      Int      @default(30)
  firstClassSeatsLeft    Int      @default(10)
  active                 Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  seats    FlightSeat[]
  bookings Booking[]
  reviews  Review[]

  @@index([origin, destination])
  @@index([departureTime])
  @@index([airline])
  @@map("flights")
}

model FlightSeat {
  id          String   @id @default(uuid())
  flightId    String
  flight      Flight   @relation(fields: [flightId], references: [id], onDelete: Cascade)
  seatClass   String   @default("ECONOMY")
  seatNumber  String
  isAvailable Boolean  @default(true)
  price       Float
  bookedBy    String?
  user        User?    @relation(fields: [bookedBy], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([flightId, seatNumber])
  @@index([flightId])
  @@map("flight_seats")
}

// ═══════════════════════════════════════════════════
// TRAINS
// ═══════════════════════════════════════════════════

model Train {
  id              String   @id @default(uuid())
  trainNumber     String   @unique
  trainName       String
  operator        String   @default("Indian Railways")
  origin          String
  originCity      String
  destination     String
  destinationCity String
  departureTime   DateTime
  arrivalTime     DateTime
  duration        Int
  distance        Int?
  daysOfWeek      String   @default("[1,2,3,4,5,6,7]")

  sleeperBasePrice    Float?
  sleeperCurrentPrice Float?
  sleeperSeatsLeft    Int?   @default(200)
  ac3BasePrice        Float?
  ac3CurrentPrice     Float?
  ac3SeatsLeft        Int?   @default(60)
  ac2BasePrice        Float?
  ac2CurrentPrice     Float?
  ac2SeatsLeft        Int?   @default(40)
  ac1BasePrice        Float?
  ac1CurrentPrice     Float?
  ac1SeatsLeft        Int?   @default(20)
  ccBasePrice         Float?
  ccCurrentPrice      Float?
  ccSeatsLeft         Int?   @default(70)
  ecBasePrice         Float?
  ecCurrentPrice      Float?
  ecSeatsLeft         Int?   @default(50)

  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings Booking[]

  @@index([origin, destination])
  @@index([departureTime])
  @@map("trains")
}

// ═══════════════════════════════════════════════════
// BUSES
// ═══════════════════════════════════════════════════

model Bus {
  id              String   @id @default(uuid())
  busNumber       String   @unique
  operator        String
  type            String   @default("AC")
  origin          String
  originCity      String
  destination     String
  destinationCity String
  departureTime   DateTime
  arrivalTime     DateTime
  duration        Int
  totalSeats      Int      @default(40)
  availableSeats  Int      @default(40)
  basePrice       Float
  currentPrice    Float
  amenities       String   @default("[]")
  boardingPoints  String   @default("[]")
  droppingPoints  String   @default("[]")
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bookings Booking[]

  @@index([origin, destination])
  @@index([departureTime])
  @@map("buses")
}

// ═══════════════════════════════════════════════════
// BOOKINGS
// ═══════════════════════════════════════════════════

model Booking {
  id          String @id @default(uuid())
  bookingRef  String @unique
  userId      String
  user        User   @relation(fields: [userId], references: [id])
  bookingType String
  status      String @default("PENDING")

  hotelId  String?
  hotel    Hotel?  @relation(fields: [hotelId], references: [id])
  flightId String?
  flight   Flight? @relation(fields: [flightId], references: [id])
  trainId  String?
  train    Train?  @relation(fields: [trainId], references: [id])
  busId    String?
  bus      Bus?    @relation(fields: [busId], references: [id])

  checkIn          DateTime?
  checkOut         DateTime?
  roomTypeId       String?
  roomCount        Int?      @default(1)
  seatNumbers      String?   @default("[]")
  seatClass        String?
  passengerDetails String?   @default("[]")
  specialRequests  String?
  adults           Int       @default(1)
  children         Int       @default(0)
  infants          Int       @default(0)

  totalAmount    Float
  baseAmount     Float
  gstAmount      Float  @default(0)
  convenienceFee Float  @default(0)
  discount       Float  @default(0)
  currency       String @default("INR")

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  expiresAt   DateTime?
  paidAt      DateTime?
  cancelledAt DateTime?
  completedAt DateTime?

  payments Payment[]

  @@index([userId])
  @@index([bookingRef])
  @@index([status])
  @@map("bookings")
}

// ═══════════════════════════════════════════════════
// PAYMENTS
// ═══════════════════════════════════════════════════

model Payment {
  id            String    @id @default(uuid())
  bookingId     String
  booking       Booking   @relation(fields: [bookingId], references: [id])
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  amount        Float
  currency      String    @default("INR")
  method        String
  methodDetail  String?
  status        String    @default("PENDING")
  transactionId String    @unique
  gateway       String    @default("DEMO_RAZORPAY")
  refundAmount  Float?
  refundReason  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  paidAt        DateTime?
  refundedAt    DateTime?

  @@index([bookingId])
  @@index([userId])
  @@index([transactionId])
  @@map("payments")
}

// ═══════════════════════════════════════════════════
// PRICE HISTORY
// ═══════════════════════════════════════════════════

model PriceHistory {
  id         String   @id @default(uuid())
  entityType String
  entityId   String
  price      Float
  seatClass  String?
  recordedAt DateTime @default(now())

  @@index([entityType, entityId])
  @@index([recordedAt])
  @@map("price_history")
}

// ═══════════════════════════════════════════════════
// REVIEWS
// ═══════════════════════════════════════════════════

model Review {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  hotelId      String?
  hotel        Hotel?   @relation(fields: [hotelId], references: [id])
  flightId     String?
  flight       Flight?  @relation(fields: [flightId], references: [id])
  rating       Int
  title        String?
  body         String
  pros         String?
  cons         String?
  verifiedStay Boolean  @default(false)
  helpfulCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([hotelId])
  @@index([flightId])
  @@index([userId])
  @@map("reviews")
}

// ═══════════════════════════════════════════════════
// SEARCH & USER FEATURES
// ═══════════════════════════════════════════════════

model SearchLog {
  id           String   @id @default(uuid())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id])
  searchType   String
  query        String
  resultsCount Int      @default(0)
  ip           String?
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([searchType])
  @@index([createdAt])
  @@map("search_logs")
}

model SavedSearch {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  searchType String
  query      String
  label      String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@map("saved_searches")
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  hotelId   String
  hotel     Hotel    @relation(fields: [hotelId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, hotelId])
  @@map("wishlists")
}
